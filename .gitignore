# Rust build artifacts
/target/
**/target/

# Rust backup files
*.rs.bk
*.rs.orig

# Cargo.lock is committed for binary crates, ignored for library crates.
# Since this is a CLI (binary), we keep Cargo.lock tracked.

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment / secrets
.env
.env.*
!.env.example

# Logs / runtime
*.log

# Git worktrees (isolated workspaces)
.worktrees/

# Claude Code hook state (记录上次检查到的 commit,用于增量检测代码变化)
.claude/.last-checked-commit


# Added by cargo

/target

# npm package binaries (构建时填充,不入版本控制)
yi-agent-rs/yi-agent-cli/platforms/*/binaries/
